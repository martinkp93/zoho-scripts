map validation_rule.ownerProtection(String crmAPIRequest)
{
// Initialise a map to hold the response (success or error)
response = Map();
// Get the record
// crmAPIRequest = {"file_content":null,"headers":null,"auth_type":null,"method":null,"user_info":{"zgid":20087400242,"org_info":{"name":"Cordulus","id":20087400242,"time_zone":"Europe/Paris"},"country":null,"time_format":"hh:mm a","name":"Rihards Savickis","id":520877000338075001,"time_zone":"Europe/Berlin","email":"rs@cordulus.com","zuid":"20112315439"},"record":{"Owner":"{\"full_name\":\"Cordulus Admin\",\"name\":\"Cordulus Admin\",\"id\":\"520877000000180021\"}","Email":"eortega@aigues-asg.es","Description":"","Meta_Lead_ID":"","Reports_To":"","Number_Of_Chats":"","Visitor_Score":"","Other_Phone":"","Twitter":"","Average_Time_Spent_Minutes":"","User_Type":"Viewer","First_Name":"Enric","Asst_Phone":"","Record_Image":"","Department":"","Skype_ID":"","Assistant":"","Phone":"","Currency":"","Schlechtwetter_Recipient":"false","Marketing_Consent":"false","Account_Name":"{\"name\":\"Aigues del Segarra Garrigues SA\",\"id\":\"520877000184748063\"}","Email_Opt_Out":"false","Reporting_To":"","Kanisa_User_ID":"","Date_of_Birth":"","Price_list":"","First_Visited_URL":"","Days_Visited":"","Credentials_Active":"false","Title":"","Mobile":"","Home_Phone":"","Marketing_Email":"","First_Visited_Time":"","User_Status":"Active","API_Key_Active":"false","Last_Name":"Ortega","Referrer":"","Last_Visited_Time":"","Fax":"","Secondary_Email":""},"params":{},"body":null};

entityMap = crmAPIRequest.toMap().get("record");


contactId = entityMap.get("id");
if(contactId != null)
{
	contact = zoho.crm.getRecordById("Contacts",contactId);
	userType = entityMap.get("User_Type");
	existingAccountId = contact.get("Account_Name").get("id");
	// Get the target Account details
	targetAccountId = entityMap.get("Account_Name").get("id");
	if(existingAccountId != targetAccountId)
	{
		targetAccount = zoho.crm.getRecordById("Accounts",targetAccountId);
		targetWorkspaceId = targetAccount.get("Kanisa_Farm_ID");
		// Check if target Account has a workspaceId; return error if null
		if(targetWorkspaceId == null)
		{
			response.put("status","error");
			response.put("message","Target Account does not have a Workspace ID. Unable to move to another Account/Workspace");
			return response;
			}
			// Check of moving Contact is owner; return error if true
			if(userType == "Owner")
			{
				response.put("status","error");
				response.put("message","Contact's Populace User is Owner. Unable to move to another Account/Workspace");
				return response;
				}
}

}
response.put("status","success");

return response;
}