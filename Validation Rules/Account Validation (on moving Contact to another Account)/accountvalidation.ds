map validation_rule.accountvalidation(String crmAPIRequest)
{
/* Convert the payload to a map to extract the record being saved */
entityMap = crmAPIRequest.toMap().get("record");
response = Map();
// 1. Get the Contact ID.
contactId = entityMap.get("id");
if(contactId != null && contactId != "")
{
	// 2. Fetch the existing Contact from CRM to compare previous values
	existingContact = zoho.crm.getRecordById("Contacts",contactId.toLong());
	// 3. Determine the User Role
	userRole = entityMap.get("User_Type");
	if(userRole == null)
	{
		userRole = existingContact.get("User_Type");
	}
	// 4. Check if the Contact is an "Owner"
	if(userRole == "Owner")
	{
		// 5. Get the new and old Account objects (Lookup fields are maps in Deluge)
		newAccount = entityMap.get("Account_Name");
		oldAccount = existingContact.get("Account_Name");
		newAccountId = if(newAccount != null,newAccount.get("id"),"");
		oldAccountId = if(oldAccount != null,oldAccount.get("id"),"");
		// 6. If the Account IDs do not match, they are trying to move the Contact. Block it.
		if(newAccountId != oldAccountId)
		{
			response.put("status","error");
			response.put("message","Validation Failed: You cannot move a Contact to another Account if their User Role is 'Owner'.");
			return response;
		}
	}
}
response.put('status','success');
return response;
}